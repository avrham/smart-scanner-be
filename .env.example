# Smart Scanner Backend - environment template
# Copy to .env and fill in real values. NEVER commit the real .env.
#   cp .env.example .env
#
# Names below are the EXACT names the app reads (app/config.py, pydantic
# BaseSettings, case_sensitive=True). Do not rename them.

# ---------------------------------------------------------------------------
# Supabase / Postgres (REQUIRED)
# ---------------------------------------------------------------------------
# NOTE: This backend does NOT use a single DATABASE_URL. It derives the
# Postgres DSN at runtime (app/deps.py) from:
#   - SUPABASE_URL  -> the project ref (subdomain) is parsed out of this
#   - SUPABASE_REGION
#   - SUPABASE_DB_PASSWORD
# It then tries pooler:6543, pooler:5432, then the direct db host.

# Project URL, e.g. https://abcdefghijklmnop.supabase.co
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# service_role key (server-side only, full access). Keep secret.
SUPABASE_SERVICE_KEY=your-service-role-key

# anon/public key.
SUPABASE_ANON_KEY=your-anon-key

# Database password (Project Settings -> Database -> Connection string / password)
SUPABASE_DB_PASSWORD=your-db-password

# Region of the Supabase project's pooler host (aws-0-<region>.pooler.supabase.com).
# Find it in Project Settings -> Database -> Connection pooling host.
SUPABASE_REGION=eu-central-1

# ---------------------------------------------------------------------------
# Market data provider selection
# ---------------------------------------------------------------------------
# "massive" (default, primary) or "fmp" (fallback).
# MARKET_DATA_PROVIDER=massive

# ---------------------------------------------------------------------------
# MASSIVE API (primary provider; REQUIRED when MARKET_DATA_PROVIDER=massive)
# ---------------------------------------------------------------------------
MASSIVE_API_KEY=your-massive-api-key
# Optional overrides (defaults shown):
# MASSIVE_BASE_URL=https://api.massive.com
# MASSIVE_REQUESTS_PER_MINUTE=5        # Massive Basic plan rate limit
# MASSIVE_PROFILE_CACHE_DAYS=7         # ticker-details (market cap) cache
# Universe eligibility + local pre-screen (defaults shown):
# UNIVERSE_ALLOWED_EXCHANGES=["XNAS","XNYS","XASE"]
# UNIVERSE_ALLOWED_SECURITY_TYPES=["CS"]
# UNIVERSE_INCLUDE_OTC=false
# PRESCREEN_MIN_PRICE=1.0
# PRESCREEN_MIN_VOLUME=100000
# PRESCREEN_MIN_DOLLAR_VOLUME=1000000

# ---------------------------------------------------------------------------
# FMP (Financial Modeling Prep) (fallback provider; REQUIRED for legacy scans
# and outcome calculation)
# ---------------------------------------------------------------------------
FMP_API_KEY=your-fmp-api-key
# Optional overrides (defaults shown):
# FMP_BASE_URL=https://financialmodelingprep.com/api/v3
# FMP_MAX_CONCURRENT=10
# FMP_RATE_LIMIT_PER_MIN=250

# ---------------------------------------------------------------------------
# Worker / admin auth (REQUIRED)
# ---------------------------------------------------------------------------
# Shared secret sent as X-Worker-Token to protect admin/scan endpoints.
# Must match WORKER_TOKEN configured for the frontend.
WORKER_TOKEN=generate-a-long-random-string
# Set to true to enforce the worker token on protected endpoints (default false).
# REQUIRE_WORKER_TOKEN=false

# ---------------------------------------------------------------------------
# Scheduler / scanner (optional; defaults shown)
# ---------------------------------------------------------------------------
# Single authoritative in-process APScheduler.
# RECOMMENDED during initial validation: keep this false so no scans auto-trigger
# (scans call paid FMP endpoints). Set to true for normal operation once verified.
# NOTE: the in-code default is true; this template ships false on purpose.
ENABLE_SCHEDULER=false
# SCAN_BATCH_SIZE=150
# SCAN_TIMES=["10:00","14:00","18:00"]

# ---------------------------------------------------------------------------
# App / logging (optional; defaults shown)
# ---------------------------------------------------------------------------
# ENVIRONMENT=development
# DEBUG=true
# LOG_LEVEL=INFO
# LOG_FORMAT=json
# DEBUG_SAVE_AVOID=false
# ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001","https://*.vercel.app"]
